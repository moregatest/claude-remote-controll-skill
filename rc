#!/bin/zsh
# rc - Claude Remote Control Session Manager
# See https://github.com/moregatest/claude-remote-controll-skill for install instructions

RC_PIDS_DIR="$HOME/.claude/rc-pids"
# Override default base directory via environment variable
CODES_DIR="${RC_CODES_DIR:-$HOME/Codes}"

RC_REPO="https://github.com/moregatest/claude-remote-controll-skill"
RC_INSTALL_PATH="${RC_INSTALL_PATH:-$(which rc 2>/dev/null)}"
RC_INSTALL_PATH="${RC_INSTALL_PATH:-/usr/local/bin/rc}"

_rc_usage() {
  echo "Usage:"
  echo "  rc start <dir|path> [--effort <level>]   Start a remote-control session"
  echo "  rc list               List all running sessions"
  echo "  rc stop <dir|path>    Stop a running session"
  echo "  rc update             Update rc to the latest version"
  echo "  rc uninstall          Remove rc from the system"
  echo ""
  echo "  <dir> is resolved relative to \$RC_CODES_DIR (default: ~/Codes)"
  echo "  Absolute paths and ~/... paths are also accepted."
  echo "  --effort levels: low, normal, high, highmax (default: none)"
  echo ""
  echo "  Environment:"
  echo "    RC_CODES_DIR     Base directory for relative dir names (default: ~/Codes)"
  echo "    RC_INSTALL_PATH  Path to the rc binary (default: $(which rc 2>/dev/null || echo '/usr/local/bin/rc'))"
}

_rc_start() {
  local input="$1"
  local effort=""

  # Parse optional --effort flag
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --effort)
        effort="$2"
        shift 2
        ;;
      *)
        input="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$input" ]]; then
    echo "Error: directory name required" >&2
    _rc_usage
    return 1
  fi

  local target
  if [[ "$input" = /* ]]; then
    target="$input"
  elif [[ "$input" = "~/"* ]]; then
    target="$HOME/${input:2}"
  else
    target="$CODES_DIR/$input"
  fi

  local name
  name=$(basename "$target")

  if [[ ! -d "$target" ]]; then
    echo "Error: directory '$target' does not exist" >&2
    return 1
  fi

  mkdir -p "$RC_PIDS_DIR"

  local pidfile="$RC_PIDS_DIR/$name.pid"
  if [[ -f "$pidfile" ]]; then
    local existing_pid
    existing_pid=$(cat "$pidfile")
    if kill -0 "$existing_pid" 2>/dev/null; then
      echo "rc-$name is already running (PID: $existing_pid)"
      return 0
    else
      rm "$pidfile"
    fi
  fi

  local effort_flag=""
  [[ -n "$effort" ]] && effort_flag="--effort $effort"

  cd "$target" && nohup claude remote-control \
    --permission-mode bypassPermissions \
    --spawn same-dir \
    --name "$name" \
    ${effort_flag:+$effort_flag} \
    > "$RC_PIDS_DIR/$name.log" 2>&1 &
  local pid=$!
  echo $pid > "$RC_PIDS_DIR/$name.pid"
  echo "已啟動 rc-$name (PID: $pid)"
}

_rc_list() {
  mkdir -p "$RC_PIDS_DIR"
  local found=0
  for pidfile in "$RC_PIDS_DIR"/*.pid(N); do
    local name
    name=$(basename "$pidfile" .pid)
    local pid
    pid=$(cat "$pidfile")
    if kill -0 "$pid" 2>/dev/null; then
      echo "$name (PID: $pid) - running"
      found=1
    else
      echo "$name (PID: $pid) - stopped"
      rm "$pidfile"
    fi
  done
  if [[ $found -eq 0 ]]; then
    echo "目前沒有 rc session 在跑"
  fi
}

_rc_stop() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Error: directory name required" >&2
    _rc_usage
    return 1
  fi

  name=$(basename "$name")

  local pidfile="$RC_PIDS_DIR/$name.pid"
  if [[ ! -f "$pidfile" ]]; then
    echo "rc-$name 不在執行中"
    return 0
  fi

  local pid
  pid=$(cat "$pidfile")
  if ! kill -0 "$pid" 2>/dev/null; then
    echo "rc-$name 不在執行中（已清除殘留 PID 檔）"
    rm "$pidfile"
    return 0
  fi

  kill "$pid"
  rm "$pidfile"
  echo "已停止 rc-$name"
}

_rc_update() {
  local tmpdir
  tmpdir=$(mktemp -d)
  trap "rm -rf $tmpdir" EXIT

  echo "Cloning latest version..."
  if ! git clone --depth 1 "$RC_REPO" "$tmpdir/repo" 2>/dev/null; then
    echo "Error: failed to clone $RC_REPO" >&2
    return 1
  fi

  local new_script="$tmpdir/repo/rc"
  if [[ ! -f "$new_script" ]]; then
    echo "Error: rc script not found in repo" >&2
    return 1
  fi

  echo "Installing to $RC_INSTALL_PATH ..."
  if [[ -w "$RC_INSTALL_PATH" ]] || [[ -w "$(dirname "$RC_INSTALL_PATH")" ]]; then
    cp "$new_script" "$RC_INSTALL_PATH"
    chmod +x "$RC_INSTALL_PATH"
  else
    sudo cp "$new_script" "$RC_INSTALL_PATH"
    sudo chmod +x "$RC_INSTALL_PATH"
  fi

  echo "Updated rc at $RC_INSTALL_PATH"
}

_rc_uninstall() {
  if [[ ! -f "$RC_INSTALL_PATH" ]]; then
    echo "rc not found at $RC_INSTALL_PATH" >&2
    return 1
  fi

  echo "This will remove $RC_INSTALL_PATH and all PID/log files under $RC_PIDS_DIR"
  echo -n "Confirm? [y/N] "
  read -r confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Aborted."
    return 0
  fi

  if [[ -w "$RC_INSTALL_PATH" ]]; then
    rm "$RC_INSTALL_PATH"
  else
    sudo rm "$RC_INSTALL_PATH"
  fi

  rm -rf "$RC_PIDS_DIR"
  echo "Uninstalled."
}

case "$1" in
  start)     shift; _rc_start "$@" ;;
  list)      _rc_list ;;
  stop)      _rc_stop "$2" ;;
  update)    _rc_update ;;
  uninstall) _rc_uninstall ;;
  *)
    _rc_usage
    exit 1
    ;;
esac
